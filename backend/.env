DB_HOST=mysql
DB_NAME=api
DB_USER=root
DB_PASS=root

JWT_SECRET_V1=super_secret_key
JWT_SECRET_V2=super_secret_key
JWT_CURRENT_KID=v1

JWT_EXPIRE=3600

# Mailer
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your_mailtrap_user
MAIL_PASSWORD=your_mailtrap_pass
MAIL_ENCRYPTION=tls
MAIL_FROM_EMAIL=noreply@sitizen.app
MAIL_FROM_NAME="SITizen"

# Invite link TTL in seconds (default 86400 = 24 h)
MAIL_VERIFY_TTL=86400

# Frontend base URL (used to build the invite link)
APP_URL=https://sitizen.app